DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
DB_SSL_MODE="disable"
PRISMA_CLIENT_ENGINE_TYPE="library"
PORT=3020

# PDFs dos caminhões (upload) — em Docker/Coolify monte volume em /app/uploads
# UPLOADS_DIR=/app/uploads

# PDF (ordem de coleta) — opcional; vazio = Chrome do Puppeteer (recomendado no Docker)
# PUPPETEER_EXECUTABLE_PATH=
# Local sem Docker: npx puppeteer browsers install chrome

# SMTP — envio de PDF (ordem de coleta / autorização)
# Microsoft 365 / Outlook (e-mail @abrottotransportes.com.br):
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=logistica@abrottotransportes.com.br
# SMTP_PASS=   # senha da caixa OU senha de app (se tiver MFA)
# MAIL_FROM=logistica@abrottotransportes.com.br
# Nunca commite a senha real — use só variáveis no Coolify ou .env local.
#
# Erro 535 / "SmtpClientAuthentication is disabled":
# No admin M365 → Usuários → caixa logistica@... → E-mail → Autenticação SMTP = habilitado
# https://aka.ms/smtp_auth_disabled
