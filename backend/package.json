{
  "name": "backend",
  "version": "1.0.0",
  "description": "Sistema de Transportadora - Backend API",
  "main": "server.js",
  "scripts": {
    "postinstall": "node -e \"process.env.PRISMA_CLIENT_ENGINE_TYPE='library'; require('child_process').execSync('npx prisma generate', { stdio: 'inherit' })\"",
    "ensure-chrome": "node scripts/ensure-chrome.mjs",
    "prestart": "node -e \"process.env.PRISMA_CLIENT_ENGINE_TYPE='library'; const cp=require('child_process'); cp.execSync('npx prisma generate', { stdio: 'inherit' }); cp.execSync('node scripts/baseline-and-deploy.mjs', { stdio: 'inherit' });\" && node scripts/ensure-chrome.mjs",
    "dev": "node --watch server.js",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:migrate": "node scripts/baseline-and-deploy.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test tests/unit/**/*.test.js tests/integration/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "start": "node server.js"
  },
  "keywords": [
    "transportadora",
    "logistics",
    "fleet-management"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "puppeteer": "^24.15.0",
    "zod": "^4.1.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
