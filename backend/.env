# Banco
DATABASE_URL="postgresql://user:password@localhost:5432/transportadora"
DB_SSL_MODE="require"

# App
PORT=3000
NODE_ENV="development"
CORS_ORIGINS="https://abbroto.jwsoftware.com.br,http://localhost:5173,http://localhost:5174"
TRUST_PROXY=1

# Segurança
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_ENABLED=false
API_TOKEN=""
ADMIN_ROLES="admin,owner"

# Logs
LOG_LEVEL="info"
