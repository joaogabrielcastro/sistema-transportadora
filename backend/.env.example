DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
DB_SSL_MODE="disable"
PRISMA_CLIENT_ENGINE_TYPE="library"
PORT=3020

# PDF (ordem de coleta) — obrigatório em produção com Docker
# Use /usr/bin/chromium (Debian). NÃO use /usr/bin/chromium-browser (Snap no Ubuntu).
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_SKIP_DOWNLOAD=true

# SMTP para envio de ordens de coleta
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
